// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {

  provider = "prisma-client-js"

}
 
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
model Employee {

  id                  Int            @id @default(autoincrement())

  name                String         @unique

  email               String         @unique

  role                String         // org hierarchy: intern, employee, teamlead, manager

  bot_role            String         @default("employee") // employee, approver, hr

  manager             String?

  manager_email       String?

  manager_teams_id    String?

  teamlead            String?

  teamlead_email      String?

  teamlead_teams_id   String?

  teams_id            String?        @unique

  leave_balance       Float          @default(22)

  created_at          DateTime       @default(now())

  updated_at          DateTime       @updatedAt
 
  leaveRequests       LeaveRequest[] @relation("EmployeeLeave")

  conversationRef     ConversationRef?

}
 
model LeaveRequest {

  id                Int       @id @default(autoincrement())

  employee          String

  email             String

  type              String    // WFH, LEAVE, SICK, MATERNITY, PATERNITY, ADOPTION, MARRIAGE

  date              String    // YYYY-MM-DD

  end_date          String?

  duration          String    // full_day, half_day, multi_day

  days_count        Float     @default(1)

  reason            String?

  rejection_reason  String?

  status            String    @default("Pending") // Pending, Approved, Rejected, Deleted

  approved_by       String?

  deleted_by        String?

  deleted_at        DateTime?

  requested_at      DateTime  @default(now())

  updated_at        DateTime  @updatedAt
 
  employeeRef       Employee  @relation("EmployeeLeave", fields: [employee], references: [name])

}
 
model ConversationRef {

  id              Int      @id @default(autoincrement())

  userId          String   @unique

  userName        String   @unique

  conversationId  String

  serviceUrl      String

  tenantId        String?

  botId           String

  isPersonal      Boolean  @default(false)

  updatedAt       DateTime @updatedAt
 
  employee        Employee? @relation(fields: [userName], references: [name])

}
 
model Holiday {

  id         Int      @id @default(autoincrement())

  date       String   @unique // YYYY-MM-DD

  name       String

  added_by   String

  added_at   DateTime @default(now())

}
 
model AuditLog {

  id              Int      @id @default(autoincrement())

  timestamp       DateTime @default(now())

  hr_name         String

  action          String   // balance_adjust, delete_request, add_holiday, add_leave_behalf

  target_employee String?

  details         String

}
 
model PendingRequest {

  id            Int      @id @default(autoincrement())

  userId        String   @unique

  userName      String

  intent        String

  date          String

  end_date      String?

  duration      String

  days_count    Float

  reason        String?

  balance_json  String   // JSON stringified LeaveBalanceResult

  history_json  String   // JSON stringified ConversationMessage[]

  created_at    DateTime @default(now())

  updated_at    DateTime @updatedAt

}
 
